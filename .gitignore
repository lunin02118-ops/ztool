# --- OS / editor ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*~
.idea/
.vs/
.vscode/
*.swp

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- .NET build output (committed release binaries in repo root are tracked) ---
[Bb]in/
[Oo]bj/
*.user

# --- chm-i18n scratch (regenerated by tools/chm-i18n/build_ru.py) ---
tools/chm-i18n/_chm_src/
tools/chm-i18n/_chm_build/

# --- local scratch / artifacts ---
*.log
*.tmp
*.bak
localization-report.json
manual-test-reports/package-smoke/
.codex-remote-attachments/

# --- local env / secrets ---
.env
.env.*
!.env.example
*.local
license-server/keys/private_key.txt
license-server/keys/keypair_info.json
license-server/keys/*.pem
license-server/keys/*.key

# --- local license/runtime state ---
license-server/*.db
license-server/*.sqlite
license-server/*.sqlite3
license-server/data/
license-server/backups/

# --- large local diagnostics ---
*.dmp
*.dump
*.wer
crash-dumps/
manual-artifacts/

# --- preflight registry backups (machine/license-state; do not commit) ---
# JSON reports / screenshots under manual-test-reports/ may be tracked as
# evidence, but raw registry exports must not be.
*.reg
manual-test-reports/**/*.reg
