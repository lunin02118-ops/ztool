<Project>
  <Target
    Name="GenerateSWToolsVersionInfo"
    BeforeTargets="CoreCompile"
    Condition="'$(MSBuildProjectName)' == 'ZTool' or '$(MSBuildProjectName)' == 'ZTool.SwAddin'">
    <PropertyGroup>
      <SWToolsGeneratedVersionInfo>$(IntermediateOutputPath)SWTools.GeneratedVersionInfo.g.cs</SWToolsGeneratedVersionInfo>
    </PropertyGroup>
    <ItemGroup>
      <SWToolsVersionInfoLines Include="// Auto-generated by Directory.Build.targets. Do not commit generated copies." />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyProduct(&quot;$(SWToolsProductName)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyCompany(&quot;$(SWToolsCompany)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyTrademark(&quot;$(SWToolsProductName)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyCopyright(&quot;$(SWToolsProductName)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyTitle(&quot;$(SWToolsTitle)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyVersion(&quot;$(SWToolsAssemblyVersion)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyFileVersion(&quot;$(SWToolsFileVersion)&quot;)]" />
      <SWToolsVersionInfoLines Include="[assembly: System.Reflection.AssemblyInformationalVersion(&quot;$(SWToolsInformationalVersion)&quot;)]" />
    </ItemGroup>
    <WriteLinesToFile
      File="$(SWToolsGeneratedVersionInfo)"
      Lines="@(SWToolsVersionInfoLines)"
      Overwrite="true"
      Encoding="UTF-8" />
    <ItemGroup>
      <Compile Include="$(SWToolsGeneratedVersionInfo)" />
    </ItemGroup>
  </Target>
</Project>
