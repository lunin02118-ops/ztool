  <FilterRulesList>
    <CustomRule>
      <name>有表面处理的加工件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|机加;钣金;铸件;焊件</string>
        <string>$表面处理$	|@#$%|不等于	|@#$%|</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>没有表面处理的加工件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|机加;钣金;铸件;焊件</string>
        <string>$表面处理$	|@#$%|等于	|@#$%|</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>有工程图的加工件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|机加;钣金;铸件;焊件</string>
        <string>&lt;有无工程图&gt;	|@#$%|等于	|@#$%|有</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>没有工程图的加工件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|机加;钣金;铸件;焊件</string>
        <string>&lt;有无工程图&gt;	|@#$%|等于	|@#$%|无</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>加工件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|机加;钣金;铸件;焊件</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>缺必填属性的项</name>
      <type>true</type>
      <RuleList>
        <string>%类型%	|@#$%|等于	|@#$%|</string>
        <string>%图号%	|@#$%|等于	|@#$%|</string>
        <string>%材料%	|@#$%|等于	|@#$%|</string>
        <string>%重量%	|@#$%|等于	|@#$%|</string>
        <string>%零件名称%	|@#$%|等于	|@#$%|</string>
      </RuleList>
    </CustomRule>
    <CustomRule>
      <name>外购件</name>
      <type>false</type>
      <RuleList>
        <string>$类型$	|@#$%|包含	|@#$%|外购;市购;</string>
      </RuleList>
    </CustomRule>
  </FilterRulesList>
