# Copy to /etc/swtools-license-server/swtools-license-server.env and edit paths.
# Do not put real private keys into git.

SWTOOLS_RUNTIME_ENV=production
SWTOOLS_LOG_LEVEL=INFO
SWTOOLS_HOST=0.0.0.0
SWTOOLS_PORT=58000

SWTOOLS_PRIVATE_KEY_FILE=/etc/swtools-license-server/private_key.txt
SWTOOLS_PUBLIC_KEY_FILE=/etc/swtools-license-server/public_key.txt
SWTOOLS_DB_PATH=/var/lib/swtools-license-server/licenses.db

SWTOOLS_DEVICE_LIMIT=1
SWTOOLS_CLIENT_VERSION=1.0

SWTOOLS_MAX_BODY_SIZE=2097152
SWTOOLS_MAX_FRAMES_PER_CONNECTION=16
SWTOOLS_READ_TIMEOUT_SECONDS=10
SWTOOLS_IDLE_TIMEOUT_SECONDS=30

SWTOOLS_PENDING_ACTIVATION_TTL_SECONDS=600
SWTOOLS_PENDING_TRANSFER_TTL_SECONDS=600

SWTOOLS_BACKUP_DIR=/var/backups/swtools-license-server
SWTOOLS_BACKUP_RETENTION_DAYS=30
