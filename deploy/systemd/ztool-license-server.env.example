# Copy to /etc/ztool-license-server/ztool-license-server.env and edit paths.
# Do not put real private keys into git.

ZTOOL_RUNTIME_ENV=production
ZTOOL_LOG_LEVEL=INFO
ZTOOL_HOST=0.0.0.0
ZTOOL_PORT=58000

ZTOOL_PRIVATE_KEY_FILE=/etc/ztool-license-server/private_key.txt
ZTOOL_PUBLIC_KEY_FILE=/etc/ztool-license-server/public_key.txt
ZTOOL_DB_PATH=/var/lib/ztool-license-server/licenses.db

ZTOOL_DEVICE_LIMIT=1
ZTOOL_CLIENT_VERSION=1.0

ZTOOL_MAX_BODY_SIZE=2097152
ZTOOL_MAX_FRAMES_PER_CONNECTION=16
ZTOOL_READ_TIMEOUT_SECONDS=10
ZTOOL_IDLE_TIMEOUT_SECONDS=30

ZTOOL_PENDING_ACTIVATION_TTL_SECONDS=600
ZTOOL_PENDING_TRANSFER_TTL_SECONDS=600

ZTOOL_BACKUP_DIR=/var/backups/ztool-license-server
ZTOOL_BACKUP_RETENTION_DAYS=30
